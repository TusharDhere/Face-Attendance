# .env  —  fill in your values, NEVER commit this file.

# ── Firebase (Realtime DB + Firestore — both free-tier friendly) ──────────────
FIREBASE_KEY_PATH=serviceAccountKey.json
FIREBASE_DB_URL=https://YOUR-PROJECT-default-rtdb.firebaseio.com/
# FIREBASE_BUCKET is OPTIONAL — this project stores photos on Cloudinary, not
# Firebase Storage (which requires the paid Blaze plan). Leave commented out
# unless you have another reason to need a Storage bucket.
# FIREBASE_BUCKET=YOUR-PROJECT.appspot.com

# FIRESTORE_DATABASE_ID is OPTIONAL — only set this if you saw the error
# "The Cloud Firestore API is not available for Firestore in Datastore Mode".
# That means your (default) database was provisioned in Datastore Mode and
# can't be used. Fix: Firebase console → Firestore Database → Add database →
# Firestore in Native mode → give it an ID → put that ID here.
# FIRESTORE_DATABASE_ID=face-attendance

# ── Cloudinary photo storage (free 25 GB — replaces Firebase Storage) ─────────
# Sign up free at https://cloudinary.com/users/register/free (no credit card)
# Dashboard → API Keys → copy all three values below
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Flask admin panel ─────────────────────────────────────────────────────────
FLASK_SECRET=replace-with-a-long-random-string
ADMIN_USER=admin
ADMIN_PASS=change-me

# ── SMTP email notifications (optional — leave blank to disable) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
